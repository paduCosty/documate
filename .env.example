APP_NAME=Documate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db          # numele serviciului din docker-compose
DB_PORT=3306
DB_DATABASE=documate
DB_USERNAME=documate
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Queue / Cache / Session ───────────────────────────────────────────────────
QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (local: log, prod: smtp/resend/mailgun) ──────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@documate.io"
MAIL_FROM_NAME="Documate"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (din Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── Social Auth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
