APP_NAME=Documate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db          # numele serviciului din docker-compose
DB_PORT=3306
DB_DATABASE=documate
DB_USERNAME=documate
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Queue / Cache / Session ───────────────────────────────────────────────────
QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (local: log, prod: smtp/resend/mailgun) ──────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@documate.nexkit.app"
MAIL_FROM_NAME="Documate"
MAIL_CONTACT_ADDRESS="contact@documate.nexkit.app"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (din Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── Social Auth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
GA_ID=
VITE_GA_ID="${GA_ID}"
ADMIN_EMAIL=

# ── Contact emails ────────────────────────────────────────────────────────────
VITE_MAIL_SUPPORT="support@documate.nexkit.app"
VITE_MAIL_PRIVACY="support@documate.nexkit.app"
VITE_MAIL_LEGAL="legal@documate.nexkit.app"

# ── AI / PDF Data Extraction ──────────────────────────────────────────────────
# Provider activ: ollama | gemini | openai | claude
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=gemini

# Ollama (local dev) — rulează pe host, accesibil din Docker via host.docker.internal
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# Gemini (producție — free tier: 1500 req/zi)
GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT=30

# OpenAI (opțional)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30

# Claude / Anthropic (opțional)
CLAUDE_ENABLED=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_TIMEOUT=30

# Extraction limits
AI_MAX_FILE_SIZE_MB=20
AI_MAX_PAGES=50
AI_JSON_RETRIES=3
AI_TEXT_MAX_CHARS=8000
AI_FREE_DAILY_LIMIT=3
AI_GUEST_DAILY_LIMIT=1
